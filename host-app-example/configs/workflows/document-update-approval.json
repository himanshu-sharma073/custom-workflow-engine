{
  "id": "document-update-approval",
  "version": 3,
  "steps": [
    {
      "id": "author-submit",
      "type": "user",
      "assignment": {
        "type": "USER",
        "value": "${initiator}"
      },
      "approval": {
        "type": "ANY",
        "minApprovals": 1
      },
      "next": "quick-validate"
    },
    {
      "id": "quick-validate",
      "type": "system",
      "action": "documentService.quickValidate",
      "next": "fetch-metadata"
    },
    {
      "id": "fetch-metadata",
      "type": "api",
      "method": "GET",
      "url": "https://jsonplaceholder.typicode.com/posts/1",
      "retryAttempts": 2,
      "responseMapping": {
        "externalTitle": "$.title"
      },
      "next": "approval-decision"
    },
    {
      "id": "approval-decision",
      "type": "decision",
      "conditions": [
        {
          "expression": "approved == true",
          "next": "publish-document"
        },
        {
          "expression": "approved == false",
          "next": "reject-document"
        }
      ]
    },
    {
      "id": "publish-document",
      "type": "system",
      "action": "documentService.publish",
      "next": "end"
    },
    {
      "id": "reject-document",
      "type": "system",
      "action": "documentService.reject",
      "next": "end"
    },
    {
      "id": "end",
      "type": "end"
    }
  ]
}

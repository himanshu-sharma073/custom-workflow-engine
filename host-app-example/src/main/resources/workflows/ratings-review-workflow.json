{
  "id": "ratings-review-workflow",
  "version": 6,
  "stages": [
    "UPDATE",
    "ANALYSIS",
    "COMMITTEE",
    "POST_COMMITTEE",
    "RELEASE",
    "POST_RELEASE"
  ],
  "steps": [
    {
      "id": "update-job",
      "name": "Update Job",
      "type": "user",
      "stage": "UPDATE",
      "assignment": {
        "type": "USER",
        "value": "${initiator}"
      },
      "approval": {
        "type": "ANY",
        "minApprovals": 1
      },
      "next": "analysis"
    },
    {
      "id": "analysis",
      "name": "Analysis",
      "type": "user",
      "stage": "ANALYSIS",
      "assignment": {
        "type": "USER",
        "value": "${initiator}"
      },
      "approval": {
        "type": "ANY",
        "minApprovals": 1
      },
      "next": "committee"
    },
    {
      "id": "committee",
      "name": "Committee",
      "type": "system",
      "stage": "COMMITTEE",
      "action": "documentService.quickValidate",
      "next": "post-committee"
    },
    {
      "id": "post-committee",
      "name": "Post Committee",
      "type": "user",
      "stage": "POST_COMMITTEE",
      "assignment": {
        "type": "USER",
        "value": "${initiator}"
      },
      "approval": {
        "type": "ANY",
        "minApprovals": 1
      },
      "next": "release-approval"
    },
    {
      "id": "release-approval",
      "name": "Release Approval",
      "type": "decision",
      "stage": "RELEASE",
      "conditions": [
        {
          "expression": "approved == true",
          "next": "release"
        },
        {
          "expression": "approved != true",
          "next": "end"
        }
      ]
    },
    {
      "id": "release",
      "name": "Release",
      "type": "user",
      "stage": "RELEASE",
      "assignment": {
        "type": "USER",
        "value": "${initiator}"
      },
      "approval": {
        "type": "ANY",
        "minApprovals": 1
      },
      "next": "post-release"
    },
    {
      "id": "post-release",
      "name": "Post Release",
      "type": "system",
      "stage": "POST_RELEASE",
      "action": "documentService.publish",
      "next": "end"
    },
    {
      "id": "end",
      "name": "End",
      "type": "end",
      "stage": "POST_RELEASE"
    }
  ]
}
